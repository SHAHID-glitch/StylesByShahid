{
  "name": "stylesby-shahid",
  "version": "1.0.0",
  "description": "A world-class presentation creation platform with beautiful glassmorphism design and powerful backend features",
  "main": "index.html",
  "scripts": {
    "start": "cd backend && npm start",
    "dev": "cd backend && npm run dev",
    "build": "npm install --prefix backend",
    "postinstall": "cd backend && npm install",
    "install-all": "npm install && cd backend && npm install",
    "backend": "cd backend && node server.js",
    "serve": "npx http-server -p 8080"
  },
  "keywords": [
    "presentation",
    "design",
    "glassmorphism",
    "modern",
    "web-app",
    "nodejs",
    "mongodb",
    "jwt"
  ],
  "author": "StylesByShahid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SHAHID-glitch/StylesByShahid.git"
  },
  "bugs": {
    "url": "https://github.com/SHAHID-glitch/StylesByShahid/issues"
  },
  "homepage": "https://github.com/SHAHID-glitch/StylesByShahid#readme",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pptxgenjs": "^4.0.1",
    "openai": "^6.25.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-rate-limit": "^6.10.0",
    "joi": "^17.9.2",
    "dotenv": "^16.3.1",
    "socket.io": "^4.7.2",
    "uuid": "^13.0.0",
    "sharp": "^0.34.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
